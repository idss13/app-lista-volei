generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Jogador {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(100)
  categoria String   @db.VarChar(20)
  status    String   @db.VarChar(20)
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("jogadores")
}

model HistoricoJogador {
  id          Int      @id @default(autoincrement())
  nome        String   @db.VarChar(100)
  categoria   String   @db.VarChar(20)
  status      String   @db.VarChar(20)
  dataJogo    DateTime @map("data_jogo") @db.Date
  arquivadoEm DateTime @default(now()) @map("arquivado_em")

  @@map("historico_jogadores")
}

model Config {
  id            Int    @id
  horarioLimite String @map("horario_limite") @db.VarChar(10)
  chavePix      String @map("chave_pix") @db.VarChar(255)
  dataJogo      String @map("data_jogo") @db.VarChar(10)

  @@map("config")
}
